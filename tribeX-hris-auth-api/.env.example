NODE_ENV=development
PORT=5000
ENABLE_SWAGGER=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

API_CENTER_BASE_URL=https://api-center.example.com
API_CENTER_TRIBE_ID=your_tribe_id
API_CENTER_TRIBE_SECRET=your_tribe_secret
# Legacy fallback only:
# API_CENTER_API_KEY=your_legacy_api_key
# API_CENTER_TIMEOUT_MS=10000

JWT_SECRET=your_jwt_secret

# Gmail / Nodemailer — use a Gmail App Password (not your account password)
# Enable 2FA on the Gmail account, then go to:
# myaccount.google.com → Security → App passwords → generate one
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend URL used in email links (verification, password reset).
# Set to your production frontend URL when deployed.
APP_URL=http://localhost:3000
SUBSCRIPTION_WEBHOOK_SECRET=your-webhook-secret-here
